DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-secret-key-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (optionnel — sans ces variables, SQLite est utilisé)
# POSTGRES_DB=afripul
# POSTGRES_USER=afripul
# POSTGRES_PASSWORD=afripul
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432


# --- Assistant IA ---
# Fournisseur : ollama (local) ou gemini (API Google)
LLM_PROVIDER=gemini
LLM_CHAT_ENABLED=true
LLM_MAX_HISTORY=32



GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_FALLBACK_MODELS=gemini-2.0-flash-lite,gemini-flash-lite-latest,gemini-2.0-flash
GEMINI_RETRY_COUNT=3
GEMINI_RETRY_DELAY=2
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT=180
GEMINI_JSON_FORMAT=true
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TEMPERATURE=0.2